{
  "name": "card-crunch",
  "version": "1.0.0",
  "private": true,
  "description": "Card Crunch mobile arcade card game",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-web.mjs",
    "dev": "npm run build && node scripts/dev-server.mjs",
    "cloudflare:dev": "wrangler dev --config cloudflare/wrangler.jsonc",
    "cloudflare:deploy": "wrangler deploy --config cloudflare/wrangler.jsonc",
    "cloudflare:secret": "wrangler secret put SESSION_SECRET --config cloudflare/wrangler.jsonc",
    "cloudflare:test-live": "node scripts/verify-cloudflare-realtime.mjs",
    "cloudflare:whoami": "wrangler whoami",
    "android:sync": "npm run build && cap sync android",
    "android:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:bundle": "npm run android:sync && cd android && gradlew.bat bundleRelease",
    "android:open": "cap open android",
    "test": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/app": "8.1.1",
    "@capacitor/browser": "8.0.4",
    "@capacitor/core": "8.4.2",
    "@capacitor/haptics": "8.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.2",
    "wrangler": "4.113.0"
  }
}
